{
  "plugins": [
    {
      "id": "abstract-loading",
      "name": "Abstract Loading",
      "tagline": "Liquid light while you wait",
      "description": "A mesmerizing abstract animation using WebGL shaders — flowing, iridescent forms inspired by visual music and liquid art.",
      "author": "justinvidual",
      "category": "reflect",
      "tags": [
        "abstract",
        "animation",
        "loading",
        "visual",
        "meditative"
      ],
      "icon": "<svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 24 24\" fill=\"none\"><circle cx=\"9\" cy=\"10\" r=\"6\" fill=\"#7c3aed\" opacity=\"0.6\"/><circle cx=\"15\" cy=\"10\" r=\"6\" fill=\"#06b6d4\" opacity=\"0.6\"/><circle cx=\"12\" cy=\"15\" r=\"6\" fill=\"#ec4899\" opacity=\"0.6\"/></svg>",
      "fields": [
        {
          "kind": "number",
          "key": "duration",
          "label": "Duration (seconds)",
          "min": 5,
          "max": 120,
          "default": 15
        },
        {
          "kind": "select",
          "key": "style",
          "label": "Style",
          "options": [
            "diffusion",
            "vortex"
          ],
          "default": "diffusion"
        },
        {
          "kind": "select",
          "key": "palette",
          "label": "Palette",
          "options": [
            "jupiter",
            "cosmic",
            "aurora",
            "ember",
            "ocean",
            "water"
          ],
          "default": "jupiter"
        },
        {
          "kind": "number",
          "key": "speed",
          "label": "Speed",
          "min": 10,
          "max": 100,
          "default": 10
        }
      ],
      "connectors": [],
      "integrity": "sha256-izVhtEPWkxw3PfugQ2EvOoCtJhrGp/wDRaS+ST+/JDc=",
      "verified": true,
      "bundle": "https://raw.githubusercontent.com/friction-box-project/box-plugins/main/dist/abstract-loading/abstract-loading.js"
    }
  ]
}
