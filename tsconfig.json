{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "paths": {
      "$shared/*": ["./shared/*"]
    }
  },
  "include": ["shared/**/*.ts", "plugins/**/*.ts", "plugins/**/*.svelte"]
}
